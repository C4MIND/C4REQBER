# ── c4reqber — Environment Variables ──
# Copy this file to .env and fill in your keys.
# Required for core functionality: OPENROUTER_API_KEY

# ── LLM Provider Keys ──
OPENROUTER_API_KEY=sk-or-...
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=sk-...
XAI_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=nvapi-...
VASTAI_API_KEY=

# ── Local LLM ──
OLLAMA_URL=http://localhost:11434
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=

# ── Search & Knowledge APIs ──
BRAVE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=          # Optional (free without key; key increases limits)
CROSSREF_MAILTO=
CROSSREF_API_KEY=                  # Optional (free polite pool without key)
CINII_APPID=
PUBMED_API_KEY=
SCIMATIC_API_KEY=
UNPAYWALL_EMAIL=
CORE_API_KEY=

# ── Scientific Data Sources (P6) ──
NCBI_API_KEY=                      # Optional (increases rate limits 3→10 req/sec)
NCBI_EMAIL=                        # Required by NCBI when using API key
MATERIALS_PROJECT_API_KEY=         # Free academic API key
KAGGLE_USERNAME=                   # Required for dataset download
KAGGLE_KEY=                        # Required for dataset download
BIBSONOMY_API_KEY=                 # Free academic bookmarking
BIBSONOMY_USERNAME=                # Default: "public"
NOAA_API_KEY=                      # Free token from NOAA CDO
DRUGBANK_API_KEY=                  # Paid subscription only — stub when empty
BASE_API_KEY=                      # Manual approval required
# GTEX, UNIPROT, EUROPE_PMC, OPENALEX — no API key required

# ── Social & Publishing ──
X_BEARER_TOKEN=
MASTODON_ACCESS_TOKEN=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
GITHUB_TOKEN=

# ── Security ──
# For development, set a dummy secret. NEVER use these in production.
JWT_SECRET=dev-secret-change-me-in-production
C4REQBER_JWT_SECRET=dev-secret-change-me-in-production
CSRF_SECRET=dev-csrf-secret-change-me
HSM_MODE=stub
HSM_HOST=
HSM_PORT=
HSM_SLOT_ID=
HSM_PASSWORD=
HSM_KEY_LABEL=
HSM_USER_PIN=

# ── Database ──
DATABASE_URL=sqlite:///data/c4reqber.db
DB_HOST=
DB_PORT=
DB_NAME=c4reqber
DB_USER=
DB_PASSWORD=

# ── Cache & Storage ──
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ── Verification Tools ──
LEAN4_PATH=
COQ_PATH=
DAFNY_PATH=
Z3_PATH=

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_KEYS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30

# ── Observability ──
LOG_LEVEL=INFO
SENTRY_DSN=
ENABLE_OPENTELEMETRY=false

# ── Feature Flags ──
LLM_COUNCIL=false
LLM_COUNCIL_BUDGET=balanced
RETRY_MAX_ATTEMPTS=3
SKIP_EXPENSIVE_VERIFICATION=false

# ── Additional LLM Providers ──
OPENAI_API_KEY=
OPENAI_BASE_URL=
GROK_API_KEY=
LIQUID_API_KEY=
LIQUID_URL=
MLX_MODEL=
YANDEX_API_KEY=
YANDEX_API_URL=
YANDEX_FOLDER_ID=
LAMBDA_API_KEY=
RUNPOD_API_KEY=
OPENFANG_API_KEY=
OPENFANG_API_URL=

# ── Auto-Formalization (P0) ──
AUTO_FORMALIZATION_ENABLED=true
AUTO_FORMALIZATION_MIN_CONFIDENCE=0.7
AUTO_FORMALIZATION_MAX_COST=5.0
AUTO_FORMALIZATION_HUMAN_GATE=0.9

# ── Database Pool ──
POOL_SIZE=5
MAX_OVERFLOW=10
POOL_TIMEOUT=30
POOL_RECYCLE=3600
POOL_PRE_PING=true

# ── Rate Limiting ──
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_ENDPOINTS=default
RATE_LIMIT_RPM=60

# ── Payment Providers ──
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Social / Integrations (additional) ──
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
XAI_BASE_URL=
DEEPSEEK_BASE_URL=
MISTRAL_BASE_URL=
MOONSHOT_BASE_URL=
NVIDIA_API_URL=
OPENROUTER_BASE_URL=

# ── Archive / Export ──
ARXIV_SUBMISSION_KEY=
ZENODO_ACCESS_TOKEN=
AI_ARCHIVE_API_KEY=
RSCI_API_KEY=
SCHOLARA_API_KEY=

# ── Misc ──
APP_VERSION=
RELEASE_VERSION=
ENV=development
ENVIRONMENT=development
C4REQBER_MODE=standard
C4REQBER_KEYRING_TOKEN=
DEV_MODE=false
DEV_MODE_BYPASS_TOKEN=
DEV_USER_ID=
DEV_USER_NAME=
AUDIT_LOG_DIR=./audit
TEMP=
TMPDIR=/tmp
WEBHOOK_SECRET=
SECURE_COOKIES=true
FEDERATED_PEERS=
OTLP_ENDPOINT=
SENTRY_DEV=
LOG_FORMAT=text
EIGENT_API_PORT=
EIGENT_HOME=
ENABLE_MATLAB=false

# ── Retry Configuration ──
RETRY_ENABLED=true
RETRY_BACKOFF_BASE=2.0
