# c4reqber GitIgnore
# ==================

# Environment & Secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
secrets/
config/secrets/

# API Keys & Tokens
*api_key*
*apikey*
# Removed: *token* was too broad, use specific rules
*secret*
openrouter_key.txt
ollama_config.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
