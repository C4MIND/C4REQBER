/-- All 27 × 27 = 729 pairwise distances in Z₃³ are ≤ 6 (exhaustive). -/
def allC4States : List C4State :=
  (List.range 3).bind (λ x =>
    (List.range 3).bind (λ y =>
      (List.range 3).map (λ z => C4State.mk x y z)))

example : (allC4States.bind (λ s =>
