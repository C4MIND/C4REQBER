/-- Power-law forgetting: F(N) = N^{-α} (experimental prediction P3). -/
def powerLawForgetting (N : ℝ) (α : ℝ) : ℝ :=
  N ^ (-α)

/-- Theorem 9 (Scaling Law for Forgetting):
    For α > 0, larger models forget less.
    N₂ ≥ N₁ > 0, α > 0 → N₂^{-α} ≤ N₁^{-α}. -/
theorem forgetting_descales_with_size (N₁ N₂ α : ℝ) (hpos₁ : N₁ > 0)
    (hle : N₁ ≤ N₂) (hαpos : α > 0) :
    powerLawForgetting N₂ α ≤ powerLawForgetting N₁ α := by
  dsimp [powerLawForgetting]
  have hpos₂ : N₂ > 0 := by linarith
  have hrpow : N₁ ^ α ≤ N₂ ^ α :=
    Real.rpow_le_rpow_of_exponent_le hpos₁ hle (by linarith)
  have hpos_rpow₁ : N₁ ^ α > 0 := Real.rpow_pos_of_pos hpos₁ α
  have hpos_rpow₂ : N₂ ^ α > 0 := Real.rpow_pos_of_pos hpos₂ α
  -- N₂^{-α} = 1/N₂^α ≤ 1/N₁^α = N₁^{-α}
  calc
    N₂ ^ (-α) = (N₂ ^ α)⁻¹ := by simp [Real.rpow_neg (by linarith : 0 ≤ N₂)]
    _ ≤ (N₁ ^ α)⁻¹ := (one_div_le_one_div hpos_rpow₂ hpos_rpow₁).mpr hrpow
    _ = N₁ ^ (-α) := by simp [Real.rpow_neg (by linarith : 0 ≤ N₁)]

-- ============================================================
-- SECTION 8: IRREVERSIBLE FORGETTING (TRIZ Principle 10 — Prior Action)
-- ============================================================

/-- Cumulative forgetting after T tasks: sum of per-task forgetting. -/
def cumulativeForgetting (measures : List ForgettingMeasure) : ℝ :=
  (measures.map forgetting).sum

/-- Theorem 10 (Irreversibility):
    If each task causes non-negative forgetting (standard scenario),
    then cumulative forgetting is monotonic in the number of tasks. -/
theorem cumulative_forgetting_monotonic (ms : List ForgettingMeasure)
    (h_all_standard : ∀ m ∈ ms, m.finalMI ≤ m.initialMI) :
    cumulativeForgetting ms ≥ 0 := by
  dsimp [cumulativeForgetting]
  refine Finset.sum_nonneg (λ i hi => ?_)
  have h : forgetting (ms.get ⟨i, hi⟩) ≥ 0 :=
    forgetting_nonneg_standard (ms.get ⟨i, hi⟩) (h_all_standard _ (by
      simpa using hi))
  simpa

