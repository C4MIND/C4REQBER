  native_decide

-- ============================================================
-- SECTION 4: CAPACITY-FORGETTING TRADEOFF
-- ============================================================

def retentionRatio (capacity : Capacity) (tasks : List TaskInfo) : ℝ :=
  let totalBits := (tasks.map (λ t => t.requiredBits)).sum
  capacity.bits / totalBits

/-- Theorem 5 (Capacity-Forgetting Tradeoff):
    If total required information exceeds capacity, retention ratio < 1,
    meaning perfect retention over all tasks is impossible. -/
theorem capacity_forgetting_tradeoff (capacity : Capacity) (tasks : List TaskInfo)
    (h_overload : (tasks.map (λ t => t.requiredBits)).sum > capacity.bits)
    (h_total_pos : (tasks.map (λ t => t.requiredBits)).sum > 0) :
    retentionRatio capacity tasks < 1 := by
  dsimp [retentionRatio]
  exact (div_lt_one h_total_pos).mpr h_overload

/-- Example: Capacity 100, 4 tasks × 20 bits each (total 80).
    Retention ratio = 1.25 > 1 → perfect retention possible. -/
example : retentionRatio (Capacity.mk 100 (by norm_num)) ([
    TaskInfo.mk 20 (by norm_num),
    TaskInfo.mk 20 (by norm_num),
    TaskInfo.mk 20 (by norm_num),
    TaskInfo.mk 20 (by norm_num)
  ] : List TaskInfo) = 1.25 := by
  dsimp [retentionRatio]
  norm_num

/-- Example: Capacity 50, 4 tasks × 20 bits each (total 80).
    Retention ratio = 0.625 < 1 → forgetting is inevitable. -/
example : retentionRatio (Capacity.mk 50 (by norm_num)) ([
    TaskInfo.mk 20 (by norm_num),
    TaskInfo.mk 20 (by norm_num),
    TaskInfo.mk 20 (by norm_num),
    TaskInfo.mk 20 (by norm_num)
  ] : List TaskInfo) = 0.625 := by
  dsimp [retentionRatio]
  norm_num

-- ============================================================
-- SECTION 5: EFFICIENCY THEOREMS
-- ============================================================

/-- Theorem 6 (Efficiency Positivity):
    If both energy and cost are positive, efficiency is positive. -/
theorem efficiency_pos (s : Solution) (hen : s.energy > 0) (hcost : s.cost > 0) :
    efficiency s > 0 := by
  dsimp [efficiency]
  exact div_pos hen hcost

/-- Theorem 7 (Efficiency Comparison — simplified):
    For solutions with equal positive cost, efficiency ordering follows energy ordering. -/
theorem efficiency_compare_same_cost (s₁ s₂ : Solution) (he : s₁.energy > s₂.energy)
    (hcost_eq : s₁.cost = s₂.cost) (hcost_pos : s₁.cost > 0) :
    efficiency s₁ > efficiency s₂ := by
  dsimp [efficiency]
  have : s₁.energy / s₁.cost > s₂.energy / s₁.cost :=
    (div_lt_div_right hcost_pos).mpr he
  simpa [hcost_eq] using this

