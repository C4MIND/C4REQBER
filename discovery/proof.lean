-- ============================================================
-- SECTION 1: CORE DATA STRUCTURES
-- ============================================================

/-- A solution (model configuration) characterized by:
    energy = representational power (analogous to retained mutual information)
    complexity = parameter count proxy
    cost = training cost (analogous to computational budget) -/
structure Solution where
  energy : ℝ
  complexity : ℝ
  cost : ℝ
  deriving Repr, Inhabited

/-- Efficiency of a solution: retained mutual information per unit computational cost. -/
def efficiency (s : Solution) : ℝ :=
  s.energy / s.cost

/-- Information-theoretic capacity: max mutual information achievable
    between parameters and all training data. -/
structure Capacity where
  bits : ℝ
  nonneg : bits ≥ 0

/-- Forgetting measure: F(t) = MI_initial(t) - MI_final(t). -/
structure ForgettingMeasure where
  initialMI : ℝ
  finalMI : ℝ
  nonneg_init : initialMI ≥ 0
  nonneg_final : finalMI ≥ 0

def forgetting (f : ForgettingMeasure) : ℝ :=
  f.initialMI - f.finalMI

/-- Task information: mutual information required for a single task. -/
structure TaskInfo where
  requiredBits : ℝ
  nonneg : requiredBits ≥ 0

-- ============================================================
-- SECTION 2: C4 COGNITIVE SPACE (Z₃³)
-- ============================================================

structure C4State where
  x : ℕ
  y : ℕ
  z : ℕ
  deriving Repr, DecidableEq

/-- Manhattan distance in Z₃³: d(s,g) = Σ max(0, g_i - s_i).
    Only counts forward steps (non-negative coordinate changes). -/
def c4_distance (s g : C4State) : ℕ :=
  (max 0 (g.x - s.x)) + (max 0 (g.y - s.y)) + (max 0 (g.z - s.z))

-- ============================================================
-- SECTION 3: THEOREMS
-- ============================================================

/-- Theorem 1: Forgetting is bounded above by initial mutual information.
    (You cannot forget more than you initially knew.) -/
theorem forgetting_bounded (f : ForgettingMeasure) : forgetting f ≤ f.initialMI := by
  dsimp [forgetting]
  nlinarith

/-- Theorem 2: Under standard continual learning (no positive backward transfer),
    forgetting is non-negative. -/
theorem forgetting_nonneg_standard (f : ForgettingMeasure) (h_no_backward : f.finalMI ≤ f.initialMI) :
    forgetting f ≥ 0 := by
  dsimp [forgetting]
  nlinarith

/-- Theorem 3: Forgetting is non-positive iff final MI ≥ initial MI
    (i.e., positive backward transfer occurred). -/
theorem no_forgetting_iff (f : ForgettingMeasure) : forgetting f ≤ 0 ↔ f.finalMI ≥ f.initialMI := by
  dsimp [forgetting]
  constructor
  · intro h; nlinarith
  · intro h; nlinarith

/-- Theorem 4 (C4 Path Bound — Theorem 11):
    Any path in Z₃³ requires at most 6 steps.
    Proof: |x₂-x₁| ≤ 2, |y₂-y₁| ≤ 2, |z₂-z₁| ≤ 2, so sum ≤ 6. -/
theorem c4_path_bound (s g : C4State) : c4_distance s g ≤ 6 := by
  dsimp [c4_distance]
  have hx : max 0 (g.x - s.x) ≤ 2 := by omega
  have hy : max 0 (g.y - s.y) ≤ 2 := by omega
  have hz : max 0 (g.z - s.z) ≤ 2 := by omega
  omega

/-- Verification: origin(0,0,0) → insight(2,1,2) = 5 steps. -/
