/-- Corollary: Segmentation preserves efficiency positivity. -/
theorem segmentation_efficiency_pos (s₁ s₂ : Solution)
    (h₁e : s₁.energy > 0) (h₁c : s₁.cost > 0) (h₂e : s₂.energy > 0) (h₂c : s₂.cost > 0) :
