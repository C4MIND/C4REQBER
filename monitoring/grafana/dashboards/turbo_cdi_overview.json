      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Task Completion Rate",
      "type": "stat",
      "description": "Task completion rate (target >90%)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "task_completion_rate * 100",
          "legendFormat": "Task Completion Rate",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
