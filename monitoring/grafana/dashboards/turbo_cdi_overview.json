    {
      "id": 12,
      "title": "Context Drift",
      "type": "stat",
      "description": "Semantic drift between plan and execution (target <5%)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 32
      },
      "targets": [
        {
