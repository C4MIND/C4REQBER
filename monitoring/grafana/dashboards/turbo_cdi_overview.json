      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Approval Rate",
      "type": "stat",
      "description": "Human approval rate (target <30%)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "approval_rate * 100",
          "legendFormat": "Approval Rate",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
