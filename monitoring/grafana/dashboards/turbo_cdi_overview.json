{
  "id": null,
  "uid": "turbo-cdi-overview",
  "title": "TURBO-CDI Overview",
  "tags": [
    "turbo-cdi",
    "c4",
    "monitoring",
    "llm",
    "simulation",
    "verification"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "LLM Costs Over Time",
      "type": "timeseries",
      "description": "Cumulative and per-model LLM API costs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(llm_cost_usd_total[5m])",
          "legendFormat": "Cost Rate ($/s) - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "llm_cost_usd_total",
          "legendFormat": "Total Cost - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "sum(llm_cost_usd_total) by (provider)",
          "legendFormat": "Total Cost by Provider",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "USD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "LLM Token Usage",
      "type": "timeseries",
      "description": "Input and output token usage over time",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(llm_tokens_total_input[5m])",
          "legendFormat": "Input Tokens/s - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "rate(llm_tokens_total_output[5m])",
          "legendFormat": "Output Tokens/s - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "llm_tokens_total_input",
          "legendFormat": "Total Input Tokens - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "llm_tokens_total_output",
          "legendFormat": "Total Output Tokens - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "LLM Latency",
      "type": "timeseries",
      "description": "LLM API call latency in milliseconds",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, llm_latency_ms)",
          "legendFormat": "p50 Latency - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "histogram_quantile(0.90, llm_latency_ms)",
          "legendFormat": "p90 Latency - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, llm_latency_ms)",
          "legendFormat": "p99 Latency - {{model}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "LLM Calls Count",
      "type": "stat",
      "description": "Total LLM API calls",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "llm_calls_total",
          "legendFormat": "Total Calls",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "rate(llm_calls_total[5m])",
          "legendFormat": "Calls Rate (calls/s)",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Simulation Performance by Engine",
      "type": "timeseries",
      "description": "Execution time for different physics simulation engines",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, simulation_execution_time_ms)",
          "legendFormat": "p50 - {{engine_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "histogram_quantile(0.90, simulation_execution_time_ms)",
          "legendFormat": "p90 - {{engine_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "rate(simulations_total[5m])",
          "legendFormat": "Simulations Rate - {{engine_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Simulation Success Rate",
      "type": "timeseries",
      "description": "Success rate of simulations by engine type",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(simulations_success_total[5m]) / rate(simulations_total[5m]) * 100",
          "legendFormat": "Success Rate % - {{engine_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Verification Success Rate by Backend",
      "type": "timeseries",
      "description": "Success rate of formal verification by backend (Lean4, Coq, Dafny, etc.)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(verifications_verified_total[5m]) / rate(verifications_total[5m]) * 100",
          "legendFormat": "Success Rate % - {{backend}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "verification_success_rate",
          "legendFormat": "Current Success Rate - {{backend}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Verification Counts by Backend",
      "type": "bargauge",
      "description": "Verified vs Failed counts by verification backend",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "verifications_verified_total",
          "legendFormat": "Verified - {{backend}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "refId": "A",
          "expr": "verifications_failed_total",
          "legendFormat": "Failed - {{backend}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "displayMode": "gradient"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Verified"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "Cache Hit Rate",
      "type": "stat",
      "description": "Prompt caching hit rate (target >80%)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cache_hit_rate * 100",
          "legendFormat": "Cache Hit Rate",
          "datasource": {
            "type": "prometheus",
