#!/usr/bin/env python3
"""
TURBO-CDI v7.0 CLI
Command-line interface for Meta-Prime Engine

Usage:
    turbo-cdi navigate --from "(P,0,0)" --to "(F,1,0)" --domain psychology
    turbo-cdi transform --domain physics --operation ACTIVATE --target STATE
    turbo-cdi compare --domain1 philosophy --domain2 mathematics
    turbo-cdi bridge --find
    turbo-cdi list --category all
    turbo-cdi validate --domain test --operation ACTIVATE --target STATE
"""

import argparse
import json
import sys
from typing import Optional

# Add parent to path (relative for portability)
import os
BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, BASE_DIR)

from core.meta_prime_engine import (
    MetaPrimeAPI, C4State, TimeAxis, ScaleAxis, AgencyAxis,
    PentadOperation, SeptetObject, Transformation
)
from core.lambda_validator import LambdaValidator
from core.error_messages import ErrorMessenger, format_validation_report
from core.formatters import OutputFormatter, ValidationReportFormatter, NavigationReportFormatter
from data.domain_profiles import (
    ALL_DOMAINS, get_profile, get_similar_domains, find_bridge_domains,
    HUMANITIES_NAMES, EXACT_SCIENCES_NAMES
)


class TurboCDICli:
    """Main CLI interface with enhanced validation and formatting"""
    
    def __init__(self):
        self.api = MetaPrimeAPI()
        self.validator = LambdaValidator()
        self.messenger = ErrorMessenger(ALL_DOMAINS)
        self.format = 'text'  # Default format
    
    def set_format(self, fmt: str):
        """Set output format"""
        self.format = fmt.lower()
    
    def _output(self, data, text_formatter=None):
        """Output data in the selected format"""
        if self.format == 'json':
            print(OutputFormatter.to_json(data))
        elif self.format == 'csv':
            if isinstance(data, list):
                print(OutputFormatter.to_csv(data))
            else:
                print("CSV format requires list data")
        elif self.format == 'yaml':
            print(OutputFormatter.to_yaml(data))
        else:
            # Text format - use provided formatter or default to str
            if text_formatter:
                print(text_formatter(data))
            else:
                print(data)
    
    def parse_c4(self, c4_str: str) -> C4State:
        """Parse C4 string like '(P,0,0)' or 'P01'"""
        # Remove parentheses if present
        c4_str = c4_str.strip().strip('()')
        
        # Parse components
        parts = c4_str.split(',')
        if len(parts) != 3:
            # Try compact format P01
            if len(c4_str) == 3:
                parts = [c4_str[0], c4_str[1], c4_str[2]]
            else:
                raise ValueError(self.messenger.format_error('invalid_c4_format', input=c4_str))
        
        # Map time axis
        time_map = {
            'P': TimeAxis.PAST, '0': TimeAxis.PAST,
            'N': TimeAxis.PRESENT, '1': TimeAxis.PRESENT,
            'F': TimeAxis.FUTURE, '2': TimeAxis.FUTURE
        }
        
        time_val = time_map.get(parts[0].upper(), TimeAxis.PRESENT)
        scale_val = ScaleAxis(int(parts[1]))
        agency_val = AgencyAxis(int(parts[2]))
        
        return C4State(time_val, scale_val, agency_val)
    
    def cmd_navigate(self, args):
        """Navigate between C4 states"""
        try:
            from_state = self.parse_c4(args.from_state)
            to_state = self.parse_c4(args.to_state)
        except ValueError as e:
            print(f"❌ {e}")
            return
        
        if self.format == 'text':
            print(f"🧭 Navigation Plan")
            print(f"   From: {from_state}")
            print(f"   To:   {to_state}")
            print(f"   Domain: {args.domain}")
            print()
        
        result = self.api.plan_transformation(
            domain=args.domain,
            from_state=from_state,
            to_state=to_state,
            target=SeptetObject[args.target.upper()]
        )
        
        if self.format == 'json':
            print(NavigationReportFormatter.to_json(result))
            return
        elif self.format == 'text':
            print(NavigationReportFormatter.to_text(result))
            return
        
        # Default text output
        if result['valid']:
            print(f"✅ Transformation is valid")
            print(f"   Operation: {result['transformation'].operation.name}")
            print(f"   Target: {result['transformation'].target.value}")
            print(f"   Reversibility: {result['transformation'].reversibility:.2%}")
            print()
            
            path = result['path']
            if path:
                print(f"📍 Navigation Path ({len(path)} steps):")
                for i, step in enumerate(path, 1):
                    print(f"   {i}. {step.operator.name}")
                    print(f"      Resonance: {step.resonance_coefficient:.2f}")
                    print(f"      Effectiveness: {step.effectiveness():.3f}")
                print()
            
            print(f"📊 Estimated Effectiveness: {result['estimated_effectiveness']:.2%}")
        else:
            print("❌ Transformation failed validation")
    
    def cmd_transform(self, args):
        """Create and validate a transformation"""
        try:
            operation = PentadOperation[args.operation.upper()]
            target = SeptetObject[args.target.upper()]
            context = self.parse_c4(args.context) if args.context else C4State(
                TimeAxis.PRESENT, ScaleAxis.ABSTRACT, AgencyAxis.SELF
            )
        except KeyError as e:
            if 'PentadOperation' in str(e):
                print(self.messenger.format_error('invalid_operation', operation=args.operation))
            else:
                print(self.messenger.format_error('invalid_target', target=args.target))
            return
        except ValueError as e:
            print(f"❌ {e}")
            return
        
        if self.format == 'text':
            print(f"⚡ Transformation")
            print(f"   Operation: {operation.name} ({operation.value})")
            print(f"   Target: {target.value}")
            print(f"   Context: {context}")
            print(f"   Domain: {args.domain}")
            print()
        
        transformation = self.api.engine.transform(
            domain=args.domain,
            operation=operation,
            target=target,
            context=context
        )
        
        # Validate the transformation
        validation = self.validator.verify(transformation)
        
        if self.format == 'json':
            output = {
                'transformation': transformation,
                'validation': validation,
                'signature': transformation.signature()
            }
            print(OutputFormatter.to_json(output))
            return
        elif self.format == 'csv':
            # CSV output for validation checks
            print(ValidationReportFormatter.to_csv(validation))
            return
        
        # Text output
        print(f"Signature: {transformation.signature()}")
        print(f"Reversibility: {transformation.reversibility:.2%}")
        print(f"Resonance: {transformation.resonance:.2f}")
        print()
        
        # Print validation report
        print(format_validation_report(validation))
    
    def cmd_validate(self, args):
        """Explicitly validate a transformation"""
        try:
            operation = PentadOperation[args.operation.upper()]
            target = SeptetObject[args.target.upper()]
            context = self.parse_c4(args.context) if args.context else C4State(
                TimeAxis.PRESENT, ScaleAxis.ABSTRACT, AgencyAxis.SELF
            )
        except KeyError as e:
            if 'PentadOperation' in str(e):
                print(self.messenger.format_error('invalid_operation', operation=args.operation))
            else:
                print(self.messenger.format_error('invalid_target', target=args.target))
            return
        except ValueError as e:
            print(f"❌ {e}")
            return
        
        transformation = self.api.engine.transform(
            domain=args.domain,
            operation=operation,
            target=target,
            context=context
        )
        
        # Override with explicit values if provided
        if args.reversibility is not None:
            transformation.reversibility = args.reversibility
        if args.resonance is not None:
            transformation.resonance = args.resonance
        
        validation = self.validator.verify(transformation)
        
        if self.format == 'json':
            print(OutputFormatter.to_json(validation))
        elif self.format == 'csv':
            print(ValidationReportFormatter.to_csv(validation))
        else:
            print(format_validation_report(validation))
    
    def cmd_compose(self, args):
        """Compose two transformations"""
        try:
            # First transformation
            op1 = PentadOperation[args.operation1.upper()]
            target1 = SeptetObject[args.target1.upper()]
            
            # Second transformation
            op2 = PentadOperation[args.operation2.upper()]
            target2 = SeptetObject[args.target2.upper()]
        except KeyError as e:
            print(f"❌ Invalid operation or target: {e}")
            return
        
        context = C4State(TimeAxis.PRESENT, ScaleAxis.ABSTRACT, AgencyAxis.SELF)
        
        t1 = Transformation(operation=op1, target=target1, context=context)
        t2 = Transformation(operation=op2, target=target2, context=context)
        
        result = self.validator.compose(t1, t2)
        
        if self.format == 'json':
            print(OutputFormatter.to_json(result))
        else:
            if result['success']:
                print(f"✅ {result['explanation']}")
                composed = result['result']
                print(f"   Result: {composed.signature()}")
                print(f"   Reversibility: {composed.reversibility:.2f}")
            else:
                print(f"❌ {result['explanation']}")
    
    def cmd_compare(self, args):
        """Compare two domains"""
        domain1 = args.domain1
        domain2 = args.domain2
        
        profile1 = get_profile(domain1)
        profile2 = get_profile(domain2)
        
        if not profile1:
            print(self.messenger.domain_error(domain1))
            return
        
        if not profile2:
            print(self.messenger.domain_error(domain2))
            return
        
        if self.format == 'json':
            result = self.api.compare_domains(domain1, domain2)
            output = {
                'domain1': profile1,
                'domain2': profile2,
                'comparison': result
            }
            print(OutputFormatter.to_json(output))
            return
        
        print(f"🔍 Domain Comparison: {profile1.name} vs {profile2.name}")
        print()
        
        print(f"📊 Category:")
        print(f"   {domain1}: {profile1.category}")
        print(f"   {domain2}: {profile2.category}")
        print()
        
        print(f"🎯 Signatures:")
        print(f"   {domain1}: {profile1.signature}")
        print(f"   {domain2}: {profile2.signature}")
        print()
        
        print(f"📈 Pentad Distribution:")
        print(f"   {'Operation':<15} {domain1:<12} {domain2:<12}")
        print(f"   {'-'*40}")
        for op in ['ACTIVATE', 'INHIBIT', 'MODULATE', 'REGULATE', 'DISRUPT']:
            p1 = getattr(profile1.pentad, op)
            p2 = getattr(profile2.pentad, op)
            print(f"   {op:<15} {p1:<12.2f} {p2:<12.2f}")
        print()
        
        # Bridge analysis
        result = self.api.compare_domains(domain1, domain2)
        print(f"🌉 Bridge Strength: {result['bridge_strength']:.2%}")
        
        if result['homomorphisms']:
            print(f"   Found {len(result['homomorphisms'])} homomorphic transformations")
    
    def cmd_bridge(self, args):
        """Find bridge domains"""
        if self.format == 'json':
            bridges = find_bridge_domains()
            print(OutputFormatter.to_json(bridges))
            return
        
        print(f"🌉 Bridge Analysis: Connecting Two Cultures")
        print()
        
        bridges = find_bridge_domains()
        
        for discipline, connections in bridges.items():
            profile = get_profile(discipline)
            print(f"🔗 {profile.name}")
            print(f"   Signature: {profile.signature}")
            print(f"   Humanities neighbors: {', '.join(connections['humanities_neighbors'])}")
            print(f"   Exact sciences neighbors: {', '.join(connections['exact_neighbors'])}")
            print()
    
    def cmd_list(self, args):
        """List domains"""
        if args.category == "all":
            data = []
            for name in HUMANITIES_NAMES[:20]:
                profile = get_profile(name)
                data.append({
                    'name': profile.name,
                    'category': 'humanities',
                    'signature': profile.signature
                })
            for name in EXACT_SCIENCES_NAMES[:20]:
                profile = get_profile(name)
                data.append({
                    'name': profile.name,
                    'category': 'exact_sciences',
                    'signature': profile.signature
                })
            
            if self.format == 'json':
                print(OutputFormatter.to_json(data))
            elif self.format == 'csv':
                print(OutputFormatter.to_csv(data))
            elif self.format == 'table':
                print(OutputFormatter.to_table(data))
            else:
                print(f"📚 All Domains ({len(ALL_DOMAINS)} total)")
                print()
                print(f"Humanities ({len(HUMANITIES_NAMES)}):")
                for name in HUMANITIES_NAMES[:10]:
                    profile = get_profile(name)
                    print(f"   • {profile.name}: {profile.signature}")
                if len(HUMANITIES_NAMES) > 10:
                    print(f"   ... and {len(HUMANITIES_NAMES) - 10} more")
                print()
                print(f"Exact Sciences ({len(EXACT_SCIENCES_NAMES)}):")
                for name in EXACT_SCIENCES_NAMES[:10]:
                    profile = get_profile(name)
                    print(f"   • {profile.name}: {profile.signature}")
                if len(EXACT_SCIENCES_NAMES) > 10:
                    print(f"   ... and {len(EXACT_SCIENCES_NAMES) - 10} more")
        
        elif args.category == "humanities":
            if self.format == 'json':
                data = [{'name': name} for name in HUMANITIES_NAMES]
                print(OutputFormatter.to_json(data))
            else:
                print(f"📖 Humanities Domains ({len(HUMANITIES_NAMES)}):")
                for name in HUMANITIES_NAMES:
                    profile = get_profile(name)
                    print(f"   • {profile.name}")
        
        elif args.category == "exact":
            if self.format == 'json':
                data = [{'name': name} for name in EXACT_SCIENCES_NAMES]
                print(OutputFormatter.to_json(data))
            else:
                print(f"🔬 Exact Sciences ({len(EXACT_SCIENCES_NAMES)}):")
                for name in EXACT_SCIENCES_NAMES:
                    profile = get_profile(name)
                    print(f"   • {profile.name}")
        
        elif args.category == "bridge":
            print(f"🌉 Boundary Disciplines:")
            for name in ['logic', 'statistics', 'computer_science']:
                profile = get_profile(name)
                if profile:
                    print(f"   • {profile.name}: {profile.signature}")
                else:
                    print(f"   • {name}: (profile not loaded)")
    
    def cmd_analyze(self, args):
        """Analyze a domain"""
        domain = args.domain
        profile = get_profile(domain)
        
        if not profile:
            print(self.messenger.domain_error(domain))
            return
        
        if self.format == 'json':
            print(OutputFormatter.to_json(profile))
            return
        
        print(f"📊 Domain Analysis: {profile.name}")
        print()
        print(f"Category: {profile.category}")
        print(f"Subdomain: {profile.subdomain}")
        print(f"Total processes analyzed: {profile.total_processes}")
        print()
        print(f"🎯 Signature: {profile.signature}")
        print()
        
        print(f"📊 Reversibility Profile:")
        print(f"   Yes:        {profile.reversibility_yes:.1%}")
        print(f"   Conditional: {profile.reversibility_conditional:.1%}")
        print(f"   No:         {profile.reversibility_no:.1%}")
        print()
        
        # Find similar domains
        similar = get_similar_domains(domain, n=3)
        print(f"🔍 Structurally Similar Domains:")
        for sim in similar:
            sim_profile = get_profile(sim)
            print(f"   • {sim_profile.name} ({sim_profile.signature})")


def main():
    cli = TurboCDICli()
    
    parser = argparse.ArgumentParser(
        description="TURBO-CDI v7.0 - Universal Transformation OS",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  turbo-cdi navigate --from "(P,0,0)" --to "(F,1,0)" --domain psychology --target STATE
  turbo-cdi transform --domain physics --operation ACTIVATE --target STRUCTURE
  turbo-cdi validate --domain test --operation ACTIVATE --target STATE --reversibility 0.8
  turbo-cdi compare --domain1 philosophy --domain2 mathematics
  turbo-cdi bridge --find
  turbo-cdi list --category all
  turbo-cdi analyze --domain computer_science
  
  # With output format:
  turbo-cdi --format json transform --domain physics --operation ACTIVATE --target STATE
  turbo-cdi --format csv list --category all
        """
    )
    
    # Global options
    parser.add_argument('--format', choices=['text', 'json', 'csv', 'yaml', 'table'],
                       default='text', help='Output format (default: text)')
    parser.add_argument('--version', action='version', version='TURBO-CDI v7.0')
    
    subparsers = parser.add_subparsers(dest='command', help='Command to run')
    
    # Navigate command
    nav_parser = subparsers.add_parser('navigate', help='Navigate between C4 states')
    nav_parser.add_argument('--from', dest='from_state', required=True, help='Starting C4 state (e.g., "(P,0,0)")')
    nav_parser.add_argument('--to', dest='to_state', required=True, help='Target C4 state')
    nav_parser.add_argument('--domain', required=True, help='Domain context')
    nav_parser.add_argument('--target', required=True, help='Septet target (STATE, STRUCTURE, etc.)')
    
    # Transform command
    trans_parser = subparsers.add_parser('transform', help='Create transformation')
    trans_parser.add_argument('--domain', required=True, help='Domain')
    trans_parser.add_argument('--operation', required=True, help='Pentad operation (ACTIVATE, INHIBIT, etc.)')
    trans_parser.add_argument('--target', required=True, help='Septet target')
    trans_parser.add_argument('--context', help='C4 context (optional)')
    
    # Validate command
    validate_parser = subparsers.add_parser('validate', help='Validate a transformation')
    validate_parser.add_argument('--domain', required=True, help='Domain')
    validate_parser.add_argument('--operation', required=True, help='Pentad operation')
    validate_parser.add_argument('--target', required=True, help='Septet target')
    validate_parser.add_argument('--context', help='C4 context (optional)')
    validate_parser.add_argument('--reversibility', type=float, help='Reversibility value (0.0-1.0)')
    validate_parser.add_argument('--resonance', type=float, help='Resonance value (0.0-1.0)')
    
    # Compose command
    compose_parser = subparsers.add_parser('compose', help='Compose two transformations')
    compose_parser.add_argument('--operation1', required=True, help='First operation')
    compose_parser.add_argument('--target1', required=True, help='First target')
    compose_parser.add_argument('--operation2', required=True, help='Second operation')
    compose_parser.add_argument('--target2', required=True, help='Second target')
    
    # Compare command
    cmp_parser = subparsers.add_parser('compare', help='Compare two domains')
    cmp_parser.add_argument('--domain1', required=True, help='First domain')
    cmp_parser.add_argument('--domain2', required=True, help='Second domain')
    
    # Bridge command
    bridge_parser = subparsers.add_parser('bridge', help='Find bridge domains')
    bridge_parser.add_argument('--find', action='store_true', help='Find bridges')
    
    # List command
    list_parser = subparsers.add_parser('list', help='List domains')
    list_parser.add_argument('--category', choices=['all', 'humanities', 'exact', 'bridge'], 
                            default='all', help='Category to list')
    
    # Analyze command
    analyze_parser = subparsers.add_parser('analyze', help='Analyze a domain')
    analyze_parser.add_argument('--domain', required=True, help='Domain to analyze')
    
    args = parser.parse_args()
    
    # Set output format
    cli.set_format(args.format)
    
    if not args.command:
        parser.print_help()
        return
    
    # Route to appropriate command
    command_map = {
        'navigate': cli.cmd_navigate,
        'transform': cli.cmd_transform,
        'validate': cli.cmd_validate,
        'compose': cli.cmd_compose,
        'compare': cli.cmd_compare,
        'bridge': cli.cmd_bridge,
        'list': cli.cmd_list,
        'analyze': cli.cmd_analyze,
    }
    
    if args.command in command_map:
        command_map[args.command](args)
    else:
        parser.print_help()


if __name__ == '__main__':
    main()
