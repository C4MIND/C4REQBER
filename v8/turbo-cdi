def parse_c4_state(state_str: str) -> C4State:
    """Parse C4 state from string like '(P,0,0)' or 'P00'"""
    clean = state_str.strip().replace('C4', '').replace('(', '').replace(')', '')

    parts = [p.strip() for p in clean.split(',')]

    if len(parts) == 3:
        time_char = parts[0].upper()
        scale_val = int(parts[1])
        agency_val = int(parts[2])
    elif len(parts) == 1 and len(clean) == 3:
        time_char = clean[0].upper()
        scale_val = int(clean[1])
        agency_val = int(clean[2])
    else:
        raise click.BadParameter(f"Invalid state format: {state_str}. Use 'P00' or '(P,0,0)'")

    time_map = {'P': TimeAxis.PAST, 'C': TimeAxis.PRESENT, 'F': TimeAxis.FUTURE}
    time = time_map.get(time_char, TimeAxis.PRESENT)

    scale_map = {0: ScaleAxis.CONCRETE, 1: ScaleAxis.ABSTRACT, 2: ScaleAxis.META}
    scale = scale_map.get(scale_val, ScaleAxis.CONCRETE)

    agency_map = {0: AgencyAxis.SELF, 1: AgencyAxis.OTHER, 2: AgencyAxis.SYSTEM}
    agency = agency_map.get(agency_val, AgencyAxis.SELF)

    return C4State(time, scale, agency)


@click.group()
@click.option('--no-emoji', is_flag=True, help='Disable emoji in output')
@click.pass_context
def cli(ctx, no_emoji):
    """TURBO-CDI v8.3 — Cognitive Operating System"""
    ctx.ensure_object(dict)
    ctx.obj['no_emoji'] = no_emoji
    ctx.obj['turbo'] = get_turbo()

def get_cli_turbo(ctx):
    """Get turbo instance from context"""
    return ctx.obj['turbo']


@cli.command()
@click.option('--from', 'from_state', required=True, help='Start state (e.g., "P00")')
@click.option('--to', 'to_state', required=True, help='Target state (e.g., "F12")')
@click.option('--domain', default='general', help='Domain context')
@click.option('--interactive', is_flag=True, help='Interactive mode')
@click.pass_context
def navigate(ctx, from_state, to_state, domain, interactive):
    """Plan transformation through C4 space"""
    turbo = get_cli_turbo(ctx)
    try:
        if interactive:
            console.print(Panel.fit("🧠 Interactive C4 Navigation Mode", style="bold blue"))
            console.print("Select dimensions for your transformation journey:")

            time = click.prompt("Time dimension", type=click.Choice(['P', 'C', 'F']),
                              default='P', show_choices=True)
            scale = click.prompt("Scale dimension", type=click.Choice(['0', '1', '2']),
                               default='0', show_choices=True)
            agency = click.prompt("Agency dimension", type=click.Choice(['0', '1', '2']),
                                default='0', show_choices=True)

            from_state = f"{time}{scale}{agency}"

            time = click.prompt("Target time dimension", type=click.Choice(['P', 'C', 'F']),
                              default='F', show_choices=True)
            scale = click.prompt("Target scale dimension", type=click.Choice(['0', '1', '2']),
                               default='2', show_choices=True)
            agency = click.prompt("Target agency dimension", type=click.Choice(['0', '1', '2']),
                                default='2', show_choices=True)

            to_state = f"{time}{scale}{agency}"

        start_state = parse_c4_state(from_state)
        end_state = parse_c4_state(to_state)

        with Progress(
            SpinnerColumn(),
            TextColumn("[progress.description]{task.description}"),
            transient=True,
        ) as progress:
            task = progress.add_task("Planning transformation...", total=1)

            plan = turbo.plan_transformation(
                from_state=start_state,
                to_state=end_state,
                domain=domain,
                target=SeptetObject.STATE
            )

            progress.update(task, advance=1)

        # Rich output
        table = Table(title=f"🌉 C4 Transformation: {from_state} → {to_state}")
        table.add_column("Step", style="cyan", no_wrap=True)
        table.add_column("Operation", style="magenta")
        table.add_column("Resonance", style="green")

        for i, step in enumerate(plan.path[:5], 1):  # Show first 5 steps
            table.add_row(
                str(i),
                f"{step.get('operator', 'Unknown')}",
                ".2f"
            )

        if len(plan.path) > 5:
            table.add_row("...", f"+{len(plan.path)-5} more steps", "")

        console.print(table)

        # Bias warnings
        if plan.bias_warnings:
            console.print(f"\n🛡️  [bold yellow]Cognitive Bias Warnings:[/bold yellow]")
            for bias in plan.bias_warnings[:3]:  # Show top 3
                console.print(f"  • {bias.type}: {bias.description}")
            if len(plan.bias_warnings) > 3:
                console.print(f"  • ... and {len(plan.bias_warnings)-3} more")

        # RAG context
        if plan.rag_context:
            console.print(f"\n📚 [bold blue]Knowledge Context:[/bold blue] {len(plan.rag_context)} sources")

    except Exception as e:
        console.print(f"[red]Error:[/red] {e}", style="bold red")
        raise click.Abort()


@cli.command()
@click.option('--trials', type=int, default=1000, help='Number of trials (100-10000)')
@click.pass_context
def falsify(ctx, trials):
    """Run Popper-style falsification suite"""
    turbo = get_cli_turbo(ctx)
    trials = max(100, min(10000, trials))

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        transient=True,
    ) as progress:
        task = progress.add_task(f"Running falsification suite ({trials} trials)...", total=trials)

        try:
            report = turbo.run_falsification_suite(n_trials=trials)

            for i in range(0, trials, 100):
                progress.update(task, advance=min(100, trials - i))

            progress.update(task, completed=trials)

            # Results
            table = Table(title="🎯 Falsification Results")
            table.add_column("Hypothesis", style="cyan")
            table.add_column("Status", style="green")
            table.add_column("Survival Rate")

            hypotheses = [
                ("Theorem 11 (≤6 steps)", report.theorem_11_survival, "100%"),
                ("Pentad Universal", report.pentad_survival, "100%"),
                ("Septet Exhaustive", report.septet_survival, "100%"),
                ("Resonance³ Model", report.resonance_survival, ".1%"),
                ("Bridge Six", report.bridge_survival, "100%"),
                ("MODULATE Dominance", report.modulate_survival, "100%"),
                ("STRUCTURE Dominance", report.structure_survival, ".1%"),
            ]

            for hypo, survived, rate in hypotheses:
                status = "[green]SURVIVED[/green]" if survived else "[red]FALSIFIED[/red]"
                table.add_row(hypo, status, rate)

            console.print(table)
            console.print(f"\n📊 [bold]Overall Survival Rate: {report.overall_survival:.1%}[/bold]")

        except Exception as e:
            progress.update(task, completed=trials)
            console.print(f"[red]Falsification failed:[/red] {e}", style="bold red")


@cli.command()
@click.option('--query', required=True, help='Query for discovery')
@click.option('--domain', default='general', help='Domain context')
@click.pass_context
def discover(ctx, query, domain):
    """Discover knowledge gaps in a domain"""
    turbo = get_cli_turbo(ctx)
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        transient=True,
    ) as progress:
        task = progress.add_task("Discovering knowledge gaps...", total=1)

        try:
            result = turbo.discover_domain(query, domain)

            progress.update(task, advance=1)

            console.print(f"🔍 [bold]Discovery Results:[/bold]")
            console.print(f"Query: {result['query']}")
            console.print(f"Domain: {result['domain']}")
            console.print(f"Gaps found: {len(result['gaps'])}")

            if result['gaps']:
                table = Table(title="🕸️ Knowledge Gap Network")
                table.add_column("#", style="cyan", no_wrap=True)
                table.add_column("Gap", style="white")
                table.add_column("Impact", style="yellow")
                table.add_column("Relations", style="magenta")

                for i, gap in enumerate(result['gaps'][:5], 1):
                    relations = []
                    gap_text = gap['description'].lower()

                    # Find related gaps by keyword overlap
                    for j, other_gap in enumerate(result['gaps']):
                        if i-1 != j:  # Not the same gap
                            other_text = other_gap['description'].lower()
                            gap_words = set(gap_text.split())
                            other_words = set(other_text.split())
                            overlap = len(gap_words.intersection(other_words))
                            if overlap > 2:  # Significant overlap
                                relations.append(f"#{j+1}")

                    relations_str = ", ".join(relations[:3]) if relations else "—"
                    impact = gap.get('impact', 'medium')
                    table.add_row(str(i), gap['description'][:60], impact, relations_str)

                console.print(table)

                if len(result['gaps']) > 5:
                    console.print(f"... and {len(result['gaps'])-5} more gaps")

        except Exception as e:
            progress.update(task, advance=1)
            console.print(f"[red]Discovery failed:[/red] {e}", style="bold red")


