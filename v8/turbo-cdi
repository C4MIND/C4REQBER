@cli.command()
@click.argument('query')
@click.option('--sources', default='scientific,user_docs', help='Sources to query')
@click.option('--top-k', type=int, default=5, help='Number of results')
@click.pass_context
def ask(ctx, query, sources, top_k):
    """Query the knowledge base"""
    turbo = get_cli_turbo(ctx)
    sources_list = [s.strip() for s in sources.split(',')]

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        transient=True,
    ) as progress:
        task = progress.add_task("Querying knowledge base...", total=1)

        try:
            result = turbo.query_knowledge_base(query, sources_list, top_k)

            progress.update(task, advance=1)

            if result['results']:
                table = Table(title=f"🔍 Query Results: '{query}'")
                table.add_column("Source", style="cyan", no_wrap=True)
                table.add_column("Title", style="magenta")
                table.add_column("Relevance", style="green", no_wrap=True)

                for r in result['results']:
                    score_val = r['score']
                    if score_val >= 0.8:
                        score_display = ".3f" + " (high)"
                    elif score_val >= 0.6:
                        score_display = ".3f" + " (medium)"
                    else:
                        score_display = ".3f" + " (low)"
                    table.add_row(r['source'], r['title'][:50], score_display)

                console.print(table)

                # Show top result preview
                top_result = result['results'][0]
                console.print(f"\n📄 [bold]Top Result:[/bold] {top_result['title']}")
                preview = top_result['text'][:200] + "..." if len(top_result['text']) > 200 else top_result['text']
                console.print(f"[dim]{preview}[/dim]")
            else:
                console.print("[yellow]No results found[/yellow]")

        except Exception as e:
            progress.update(task, advance=1)
            console.print(f"[red]Query failed:[/red] {e}", style="bold red")


@cli.command()
@click.argument('gap_id', required=False)
@click.option('--domain', default='general', help='Domain context')
@click.option('--interactive', is_flag=True, help='Interactive gap selection')
@click.pass_context
def plan_gap(ctx, gap_id, domain, interactive):
    """Transform discovered gap into C4 plan"""
    turbo = get_cli_turbo(ctx)

    if interactive:
        console.print("🔍 [bold]Interactive Gap Selection Mode[/bold]")
        console.print("Let's discover gaps first...")

        # Run discovery
        with Progress(
            SpinnerColumn(),
            TextColumn("[progress.description]{task.description}"),
            transient=True,
        ) as progress:
            task = progress.add_task("Discovering gaps in domain...", total=1)
            discovery_result = turbo.discover_domain(f"gaps in {domain}", domain)
            progress.update(task, advance=1)

        if discovery_result['gaps']:
            console.print(f"\n📋 Found {len(discovery_result['gaps'])} gaps:")
            table = Table(title="Available Gaps")
            table.add_column("#", style="cyan", no_wrap=True)
            table.add_column("Description", style="white")

            for i, gap in enumerate(discovery_result['gaps'], 1):
                table.add_row(str(i), gap['description'][:80])

            console.print(table)

            # Let user choose
            choice = click.prompt("Select gap number", type=int, min=1, max=len(discovery_result['gaps']))
            selected_gap = discovery_result['gaps'][choice - 1]
            gap_id = selected_gap['id']
            console.print(f"Selected: {selected_gap['description']}")
        else:
            console.print("[yellow]No gaps found. Using default gap_0[/yellow]")
            gap_id = "gap_0"
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        transient=True,
    ) as progress:
        task = progress.add_task("Planning gap transformation...", total=1)

        try:
            result = turbo.select_gap_and_plan(gap_id, domain)

            progress.update(task, advance=1)

            console.print("🌉 [bold]Gap Transformation Plan[/bold]")
            console.print(f"Gap: {gap_id}")
            console.print(f"From: {result['from_state']} (current knowledge)")
            console.print(f"To: {result['to_state']} (target breakthrough)")

            # Show temporal wayfinding
            console.print("\n🧭 [bold]Knowledge Space Navigation:[/bold]")
            console.print("🌍 [green]Known Space:[/green] What we currently understand")
            console.print("🌌 [blue]Unknown Space:[/blue] The gap we're bridging")
            console.print("   ↑")
            console.print(f"   You're here: {result['from_state']}")
            console.print("   ↓")
            console.print(f"   Target: {result['to_state']}")
            console.print("\n💡 This transformation will expand your understanding of the domain.")

            if result['plan'] and hasattr(result['plan'], 'path'):
                table = Table(title="Plan Steps")
                table.add_column("Step", style="cyan", no_wrap=True)
                table.add_column("Operation", style="magenta")

                for i, step in enumerate(result['plan'].path[:3], 1):
                    table.add_row(str(i), f"{step.get('operator', 'Unknown')}")

                console.print(table)

        except Exception as e:
            progress.update(task, advance=1)
            console.print(f"[red]Gap planning failed:[/red] {e}", style="bold red")


@cli.command()
@click.option('--port', type=int, default=8765, help='WebSocket port')
@click.pass_context
def server(ctx, port):
    """Start WebSocket server for real-time updates"""
    turbo = get_cli_turbo(ctx)
    console.print(f"🌐 Starting WebSocket server on ws://localhost:{port}")
    console.print("Commands: navigate, meta, falsify, discover, upload_doc, query_rag, select_gap, subscribe, ping")

    try:
        turbo.start_websocket_server(port=port)
    except KeyboardInterrupt:
        console.print("\n👋 Server stopped")


